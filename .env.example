# RepoPilot reads environment variables from the process that starts it.
# This file is a safe reference and is not loaded automatically.
# Never place a real API key or access token in a committed file.

# OpenAI-compatible LLM settings
OPENAI_API_KEY=replace-with-your-api-key
# Provide the complete Chat Completions endpoint. RepoPilot appends no path.
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
REPOPILOT_MODEL=gpt-4o-mini
REPOPILOT_LLM_TIMEOUT_SECONDS=120
# Usually leave this at 0. RepoPilot retries once without response_format when
# a provider rejects JSON mode; set it to 1 only to disable JSON mode up front.
REPOPILOT_DISABLE_JSON_MODE=0

# Optional backward-compatible alias for OPENAI_API_URL. Do not set both.
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Optional GitHub authentication for private repositories, higher rate limits,
# and explicitly confirmed pull request creation. Use either variable, not both.
# GITHUB_TOKEN=replace-with-your-github-token
# GH_TOKEN=replace-with-your-github-token

# Optional local cache location for repositories resolved from GitHub URLs.
# REPOPILOT_REPO_CACHE=.repopilot/repos
